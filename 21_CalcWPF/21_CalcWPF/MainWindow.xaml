<Window x:Class="_21_CalcWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechner" Height="250" Width="400">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Zahl 1:" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Number1, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Zahl 2:" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Number2, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Ergebnis:" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="2" Grid.Column="1"
           Text="{Binding Result}"
           Foreground="{Binding ResultColor}"
           FontWeight="Bold"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">

            <Button Content="Addition"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Command="{Binding AddCommand}"/>

            <Button Content="Subtraktion"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Command="{Binding SubCommand}"/>

            <Button Content="Multiplikation"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Command="{Binding MulCommand}"/>

            <Button Content="Division"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Command="{Binding DivCommand}"/>

        </StackPanel>

        

        <TextBlock Text="Status:" Grid.Row="4" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="4"
                   Grid.Column="1"
                   Text="{Binding Status}"/>

        <Button Grid.Row="6"
                Grid.ColumnSpan="2"
                Content="Reset"
                Width="100"
                HorizontalAlignment="Center"
                Command="{Binding ResetCommand}"/>

    </Grid>
</Window>