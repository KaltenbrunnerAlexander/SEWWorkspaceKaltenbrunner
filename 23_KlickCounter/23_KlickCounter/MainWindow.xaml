<Window x:Class="_23_KlickCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_23_KlickCounter"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        
        <Button Content="Zeitpunkt loggen" 
                FontSize="20" 
                Padding="10"
                Command="{Binding LogCommand}" 
                Background="DarkOrange"
                Foreground="White"
                FontWeight="Bold"
                />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="Gesamtanzahl Klicks: " />
            <TextBlock Text="{Binding Logs.Count}" />
        </StackPanel>

        <Label Content="Alle bisherigen Einträge:" 
               Margin="0,0,0,20"/>
        
        <ListBox ItemsSource="{Binding Logs}" 
                 Height="200" 
                 DisplayMemberPath="DisplayText" />
        
        <Button Content="Liste leeren" 
                Margin="0,10,0,0" 
                Command="{Binding ClearCommand}" />
        
    </StackPanel>
</Window>
