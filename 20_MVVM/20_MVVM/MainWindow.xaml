<Window x:Class="_20_MVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_20_MVVM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="MyConverter"></BooleanToVisibilityConverter>
    </Window.Resources>

    <StackPanel>
        <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Text="{Binding Number}"></TextBox>

        <Slider x:Name="MySlider" Minimum="0" Maximum="400"></Slider>
        <Rectangle Fill="Red" Height="100" Width="{Binding ElementName=MySlider, Path=Value}"></Rectangle>

        <CheckBox x:Name="VisibilityCheckBox">Visible</CheckBox>
        <Rectangle Fill="Blue" Width="100" Height="100"
                   Visibility="{Binding 
                    ElementName=VisibilityCheckBox, 
                    Path=IsChecked, 
                    Converter={StaticResource MyConverter}}">
        </Rectangle>
        
    </StackPanel>
</Window>
