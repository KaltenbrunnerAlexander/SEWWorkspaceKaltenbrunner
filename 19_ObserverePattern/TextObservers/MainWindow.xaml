<Window x:Class="TextObservers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextObservers"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
        <StackPanel Margin="10">

            
            <TextBox Name="InputTextBox"
                 FontSize="16"
                 Margin="0,0,0,10"
                 TextChanged="InputTextBox_TextChanged"/>

            
            <Label Name="Label1" FontSize="14"/>
            <Label Name="Label2" FontSize="14"/>
            <Label Name="Label3" FontSize="14"/>
            <Label Name="Label4" FontSize="14"/>
            <Label Name="Label5" FontSize="14"/>

        </StackPanel>
</Window>
